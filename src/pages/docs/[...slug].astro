---
import { getCollection, render } from 'astro:content';
import DocsPageLayout from '../../layouts/DocsPageLayout.astro';
import { DEFAULT_DOC_LOCALE, buildDocHref, filterPublicDocsByLocale, stripDocLocalePrefix } from '../../lib/docs';

export async function getStaticPaths() {
  const docs = filterPublicDocsByLocale(await getCollection('docs'), DEFAULT_DOC_LOCALE);
  return docs.map((entry) => ({
    params: { slug: stripDocLocalePrefix(entry.slug, DEFAULT_DOC_LOCALE) },
    props: { entry },
  }));
}

const allDocs = (await getCollection('docs')).filter((item) => !item.data.draft);
const slugParam = String(Astro.params.slug || '').replace(/^\/+|\/+$/g, '');
const entry = Astro.props.entry || allDocs.find((item) => buildDocHref(item.slug, DEFAULT_DOC_LOCALE) === `/docs/${slugParam}`);
if (!entry) {
  return Astro.redirect('/docs');
}
const { Content, headings } = await render(entry);
---

<DocsPageLayout entry={entry} allDocs={allDocs} headings={headings}>
  <Content />
</DocsPageLayout>
