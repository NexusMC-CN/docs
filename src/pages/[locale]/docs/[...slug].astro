---
import { getCollection, render } from 'astro:content';
import DocsPageLayout from '../../../layouts/DocsPageLayout.astro';
import {
  DEFAULT_DOC_LOCALE,
  DOC_LOCALES,
  buildDocHref,
  filterPublicDocsByLocale,
  normalizeDocLocale,
  stripDocLocalePrefix,
} from '../../../lib/docs';

export async function getStaticPaths() {
  const allDocs = await getCollection('docs');
  return DOC_LOCALES
    .filter((locale) => locale.code !== DEFAULT_DOC_LOCALE)
    .flatMap((locale) => {
      const docs = filterPublicDocsByLocale(allDocs, locale.code);
      return docs.map((entry) => ({
        params: {
          locale: locale.pathPrefix,
          slug: stripDocLocalePrefix(entry.slug, locale.code),
        },
        props: { entry },
      }));
    });
}

const allDocs = (await getCollection('docs')).filter((item) => !item.data.draft);
const localeParam = String(Astro.params.locale || '').trim();
const localeMeta = DOC_LOCALES.find((item) => item.pathPrefix === localeParam);
const locale = normalizeDocLocale(localeMeta?.code || DEFAULT_DOC_LOCALE);
const slugParam = String(Astro.params.slug || '').replace(/^\/+|\/+$/g, '');
const entry = Astro.props.entry || allDocs.find((item) => buildDocHref(item.slug, locale) === `/${localeParam}/docs/${slugParam}`);
if (!entry) {
  return Astro.redirect(localeMeta?.pathPrefix ? `/${localeMeta.pathPrefix}/docs` : '/docs');
}
const { Content, headings } = await render(entry);
---

<DocsPageLayout entry={entry} allDocs={allDocs} headings={headings}>
  <Content />
</DocsPageLayout>
